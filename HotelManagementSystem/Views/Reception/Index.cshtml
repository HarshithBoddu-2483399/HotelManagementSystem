@model HotelManagementSystem.ViewModels.ReceptionDashboardViewModel

@{
    ViewData["Title"] = "Front Desk Dashboard";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Front Desk Dashboard</h2>
            <div>
            <a asp-controller="Reservation" asp-action="Create" class="btn btn-primary me-2">
                    <i class="bi bi-person-plus-fill"></i> New Walk-in
                </a>
    
                <a asp-controller="Guest" asp-action="Index" class="btn btn-outline-dark">
                    <i class="bi bi-search"></i> Search Guest
                </a>
            </div>
    </div>

    <div class="row mb-5 g-3">
        <div class="col-md-3">
            <div class="card border-start border-primary border-4 shadow-sm h-100">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Today's Arrivals</h6>
                    <h2 class="display-5 text-primary fw-bold mb-0">@Model.TotalArrivals</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-start border-danger border-4 shadow-sm h-100">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Today's Departures</h6>
                    <h2 class="display-5 text-danger fw-bold mb-0">@Model.TotalDepartures</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-start border-info border-4 shadow-sm h-100">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Stay-Overs</h6>
                    <h2 class="display-5 text-info fw-bold mb-0">@Model.StayOvers</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-start border-success border-4 shadow-sm h-100">
                <div class="card-body text-center">
                    <h6 class="text-muted text-uppercase fw-bold mb-2">Available Rooms</h6>
                    <h2 class="display-5 text-success fw-bold mb-0">@Model.AvailableRooms</h2>
                </div>
            </div>
        </div>
    </div>

    <h4 class="fw-bold mb-3">Live Room Status</h4>
    <div class="row g-3">
        @foreach (var room in Model.Rooms)
        {
            // Define the card colors directly inside the loop! (No @{ needed!)
            string cardClass = "bg-secondary";
            string badgeClass = "bg-dark text-white";

            if (room.Status == "AVAILABLE") { cardClass = "bg-success"; badgeClass = "bg-white text-success"; }
            else if (room.Status == "OCCUPIED" || room.Status == "BOOKED") { cardClass = "bg-primary"; badgeClass = "bg-white text-primary"; }
            else if (room.Status == "PENDING" || room.Status == "DIRTY") { cardClass = "bg-warning"; badgeClass = "bg-dark text-warning"; }
            else if (room.Status == "MAINTENANCE") { cardClass = "bg-danger"; badgeClass = "bg-white text-danger"; }

            <div class="col-md-4 col-lg-3">
                <div class="card text-white shadow-sm @cardClass" style="border-radius: 12px; border: none;">
                    <div class="card-body">
                        
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h4 class="mb-0 fw-bold">Room @room.RoomNumber</h4>
                            <span class="badge rounded-pill fw-bold @badgeClass">@room.Status</span>
                        </div>
                        
                        <p class="mb-1 opacity-75 fw-bold">Type: @room.RoomType</p>
                        <p class="mb-3 opacity-75 fw-bold">Rate: ₹@room.RatePerNight</p>

                        @if (room.Status == "BOOKED" || room.Status == "OCCUPIED")
                        {
                            <a asp-controller="Reception" asp-action="RoomDetails" asp-route-roomId="@room.RoomId"
                                   class="btn btn-light btn-sm w-100 fw-bold mt-2" style="background-color: rgba(255,255,255,0.2); border: none; color: white;">
                                Manage Room
                            </a>
                        }
                        else if (room.Status == "AVAILABLE")
                        {
                            <div class="d-flex gap-2 mt-3">
                                <a asp-controller="Reception" asp-action="AssignRoom" asp-route-roomId="@room.RoomId"
                                       class="btn btn-light btn-sm w-50 fw-bold" style="background-color: rgba(255,255,255,0.2); border: none; color: white;">
                                    Assign
                                </a>

                                @if (Model.SafeToBook != null && Model.SafeToBook.ContainsKey(room.RoomId) && Model.SafeToBook[room.RoomId])
                                {
                                    <a asp-controller="Reservation" asp-action="Create" asp-route-roomId="@room.RoomId"
                                           class="btn btn-dark btn-sm w-50 fw-bold" style="background-color: rgba(0,0,0,0.4); border: none; color: white;">
                                        Book
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-dark btn-sm w-50 fw-bold" disabled style="background-color: rgba(0,0,0,0.1); border: none; color: white;" title="Reserved for today's arrivals">
                                        Reserved
                                    </button>
                                }
                            </div>
                        }
                        else
                        {
                            <button class="btn btn-light btn-sm w-100 fw-bold mt-2" disabled style="background-color: rgba(255,255,255,0.2); border: none; color: white;">
                                Unavailable
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>
</div>