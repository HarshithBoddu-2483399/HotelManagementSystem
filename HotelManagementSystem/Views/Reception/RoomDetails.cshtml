@model HotelManagementSystem.ViewModels.RoomDetailsViewModel
@{
    ViewData["Title"] = "Room Details";
}

<div class="container mt-4">
    <a asp-action="Index" class="btn btn-outline-secondary mb-3"><i class="bi bi-arrow-left"></i> Back to Dashboard</a>
    
    <h2>Manage Room @Model.Room.RoomNumber</h2>
    <span class="badge bg-primary fs-6 mb-4">@Model.Room.Status</span>

    <div class="card shadow-sm border-0 p-4">
        @if (Model.Reservation != null)
        {
            <h4 class="mb-4 border-bottom pb-2">Guest Information</h4>
            <div class="row mb-4">
                <div class="col-md-4"><strong>Name:</strong> <br /> @Model.GuestName</div>
                <div class="col-md-4"><strong>Phone:</strong> <br /> @Model.GuestPhone</div>
                <div class="col-md-4"><strong>Email:</strong> <br /> @Model.GuestEmail</div>
            </div>

            <h4 class="mb-4 border-bottom pb-2">Booking Details</h4>
            <div class="row">
                <div class="col-md-4"><strong>Check-In:</strong> <br /> @Model.Reservation.CheckInDate.ToString("MMM dd, yyyy")</div>
                <div class="col-md-4"><strong>Check-Out:</strong> <br /> @Model.Reservation.CheckOutDate.ToString("MMM dd, yyyy")</div>
                <div class="col-md-4"><strong>Booking Status:</strong> <br /> @Model.Reservation.ReservationStatus</div>
            </div>
            
            <hr class="my-4" />
            <div class="alert alert-secondary d-flex align-items-center justify-content-between mb-0 border-0 shadow-sm" style="background-color: #f8f9fa;">
                <div>
                    <h6 class="fw-bold mb-1"><i class="bi bi-info-circle text-primary me-2"></i> Action Required</h6>
                    <span class="text-muted">Check-In, Check-Out, and Billing settlements are securely handled in the Financials module.</span>
                </div>
                <a asp-controller="Billing" asp-action="Index" class="btn btn-primary fw-bold px-4">
                    Proceed to Financials
                </a>
            </div>
        }
        else
        {
            <p class="text-muted">No active reservation found for this room.</p>
        }
    </div>
</div>