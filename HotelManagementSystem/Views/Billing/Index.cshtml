@model IEnumerable<HotelManagementSystem.ViewModels.FinancialRecord>

<h2>Front Desk: Booking Management</h2>
<hr />

<h3>Active & Upcoming Bookings</h3>
<table style="width:100%; text-align:left; border-collapse: collapse; margin-bottom: 40px;">
    <tr style="background:#007bff; color: white;">
        <th style="padding:10px;">ID</th>
        <th style="padding:10px;">Guest Name</th>
        <th style="padding:10px;">Room</th>
        <th style="padding:10px;">Dates</th>
        <th style="padding:10px;">Status</th>
        <th style="padding:10px;">Actions</th>
    </tr>
    @foreach(var b in ViewBag.ActiveBookings) { 
        <tr style="border-bottom: 1px solid #ddd;">
            <td style="padding:10px;">@b.ReservationId</td>
            <td style="padding:10px;">@b.GuestName</td>
            <td style="padding:10px;">@b.RoomNumber</td>
            <td style="padding:10px;">@b.CheckIn.ToShortDateString() - @b.CheckOut.ToShortDateString()</td>
            <td style="padding:10px; font-weight:bold; color: @(b.Status == "BOOKED" ? "orange" : "green");">@b.Status</td>
            <td style="padding:10px; display: flex; gap: 5px;">
                
                @if(b.Status == "BOOKED") {
                    <form action="/Billing/CheckIn" method="post">
                        <input type="hidden" name="reservationId" value="@b.ReservationId" />
                        <button type="submit" style="background:#28a745; color:white; border:none; padding:5px 10px; border-radius:3px;">Check-In</button>
                    </form>
                    <form action="/Billing/Cancel" method="post">
                        <input type="hidden" name="reservationId" value="@b.ReservationId" />
                        <button type="submit" style="background:#dc3545; color:white; border:none; padding:5px 10px; border-radius:3px;">Cancel</button>
                    </form>
                }
                @if(b.Status == "COMPLETED") {
                    <form action="/Billing/Checkout" method="post">
                        <input type="hidden" name="reservationId" value="@b.ReservationId" />
                        <button type="submit" style="background:#17a2b8; color:white; border:none; padding:5px 10px; border-radius:3px;">Generate Bill & Checkout</button>
                    </form>
                }
            </td>
        </tr> 
    }
</table>

<h3>Financials: Paid Invoices</h3>
<table style="width:100%; text-align:left; border-collapse: collapse;">
    <tr style="background:#343a40; color: white;">
        <th style="padding:10px;">Invoice #</th>
        <th style="padding:10px;">Guest Name</th>
        <th style="padding:10px;">Room</th>
        <th style="padding:10px;">Date Paid</th>
        <th style="padding:10px;">Revenue</th>
    </tr>
    @foreach(var i in Model) { 
        <tr style="border-bottom: 1px solid #ddd;">
            <td style="padding:10px;">@i.InvoiceId</td>
            <td style="padding:10px;">@i.GuestName</td>
            <td style="padding:10px;">@i.RoomNumber</td>
            <td style="padding:10px;">@i.InvoiceDate.ToShortDateString()</td>
            <td style="padding:10px; color:green; font-weight:bold;">$@i.TotalAmount</td>
        </tr> 
    }
</table>