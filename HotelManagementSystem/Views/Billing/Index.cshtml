@{
    ViewData["Title"] = "Billing";
    // We create a "queue tracker" to ensure only the first guest in line can interact with a room
    var busyRooms = new System.Collections.Generic.HashSet<string>();
}

<div class="container">
    <h2>Front Desk: Booking & Financials</h2>

    <div class="card mt-3 p-3">
        <h5>Active & Upcoming Bookings</h5>
        <div class="table-responsive mt-3">
            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Res #</th>
                        <th>Guest</th>
                        <th>Room</th>
                        <th>Dates</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in ViewBag.ActiveBookings)
                    {
                        // Queue Logic: If the room is NOT in the HashSet yet, this is the first guest in line.
                        bool isFirstInQueue = !busyRooms.Contains(b.RoomNumber.ToString());
                        
                        // Immediately mark the room as busy so the next person in the loop gets locked out.
                        busyRooms.Add(b.RoomNumber.ToString());

                        <tr>
                            <td>@b.ReservationId</td>
                            <td>@b.GuestName <br /><small class="text-muted">ID: @b.GuestId</small></td>
                            <td>@b.RoomNumber</td>
                            <td>@b.CheckIn.ToShortDateString() - @b.CheckOut.ToShortDateString()</td>
                            <td>@b.Status</td>
                            <td>
                                @if (b.Status.Contains("BOOKED"))
                                {
                                    // FIXED: Relies on Queue Order instead of a strict Calendar Date
                                    @if (isFirstInQueue)
                                    {
                                        <form style="display:inline-block; margin-right:6px;" action="/Billing/CheckIn" method="post">
                                            <input type="hidden" name="reservationId" value="@b.ReservationId" />
                                            <button class="btn btn-sm btn-success" type="submit">Check-In</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-outline-secondary" style="margin-right:6px;" disabled title="Waiting for previous guest to clear">Check-In (Wait)</button>
                                    }
                                    
                                    <form style="display:inline-block;" action="/Billing/Cancel" method="post">
                                        <input type="hidden" name="reservationId" value="@b.ReservationId" />
                                        <button class="btn btn-sm btn-danger" type="submit">Cancel</button>
                                    </form>
                                }
                                else if (b.Status.Contains("CHECKED_IN") || b.Status.Contains("CHECKED-IN"))
                                {
                                    <form action="/Billing/CheckOut" method="post" style="display:inline-block; margin-right:6px;">
                                        <input type="hidden" name="reservationId" value="@b.ReservationId" />
                                        <button class="btn btn-sm btn-warning" type="submit">Check-Out</button>
                                    </form>
                                }
                                else if (b.Status.Contains("CHECKED_OUT") || b.Status.Contains("CHECKED-OUT"))
                                {
                                    <form action="/Billing/GenerateInvoice" method="post" style="display:inline-block; margin-right:6px;">
                                        <input type="hidden" name="reservationId" value="@b.ReservationId" />
                                        <button class="btn btn-sm btn-primary" type="submit">Generate Invoice</button>
                                    </form>
                                }
                                else if (b.Status == "INVOICED")
                                {
                                    <span class="badge bg-info p-2 mb-1 d-block">Invoice Ready</span>
                                }

                                @if (b.InvoiceId != null)
                                {
                                    if (b.InvoicePaid == false)
                                    {
                                        <form action="/Billing/MarkPaid" method="post" style="display:inline-block; margin-right:6px;">
                                            <input type="hidden" name="invoiceId" value="@b.InvoiceId" />
                                            <button class="btn btn-sm btn-success" type="submit">Mark Paid</button>
                                        </form>
                                    }
                                    <a class="btn btn-sm btn-secondary" href="/Billing/ViewInvoice?reservationId=@b.ReservationId">View Invoice</a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>