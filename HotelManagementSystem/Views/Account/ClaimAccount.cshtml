@model HotelManagementSystem.ViewModels.ClaimAccountViewModel

@{
    ViewData["Title"] = "Claim Account";
    ViewData["HideSidebar"] = true;
}

<div class="col-md-8 col-lg-6 my-4">
    <div class="card glass-card">
        <div class="card-body p-4">
            
            <div class="text-center mb-3">
                <h3 class="fw-bold text-primary">Claim Your Account</h3>
                <p class="text-muted small">Booked at the front desk? Enter your details below to set up your online portal access.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center fw-bold py-2">
                    <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                </div>
            }

            <form asp-controller="Account" asp-action="ClaimAccount" method="post">
                <div class="mb-3 p-2 bg-light border rounded">
                    <label class="form-label fw-bold text-dark small mb-1">Reservation ID</label>
                    <input type="number" name="ReservationId" class="form-control border-primary" placeholder="e.g., 104" required />
                    <small class="text-muted" style="font-size: 0.75rem;">Find this on your email receipt or paper invoice.</small>
                </div>

                <div class="row mb-2">
                    <div class="col-sm-6 mb-2 mb-sm-0">
                        <label class="form-label fw-bold small mb-1">Registered Email</label>
                        <input type="email" name="Email" class="form-control" placeholder="name@example.com" required />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label fw-bold small mb-1">Registered Phone</label>
                        <input type="text" name="Phone" class="form-control" pattern="\d{10}" placeholder="10-digit number" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '');" required />
                    </div>
                </div>

                <div class="mb-3 p-2 bg-light border border-success rounded">
                    <label class="form-label fw-bold text-success small mb-1">Create a 4-Digit Recovery PIN</label>
                    <input type="text" name="RecoveryPin" class="form-control border-success" pattern="\d{4}" maxlength="4" placeholder="e.g. 1234" oninput="this.value = this.value.replace(/[^0-9]/g, '');" required />
                </div>

                <div class="row mb-3">
                    <div class="col-sm-6 mb-2 mb-sm-0">
                        <label class="form-label fw-bold small mb-1">New Password</label>
                        <input type="password" id="newPass" name="NewPassword" class="form-control" minlength="6" required />
                    </div>
                    <div class="col-sm-6">
                        <label class="form-label fw-bold small mb-1">Confirm Password</label>
                        <input type="password" id="confirmPass" name="ConfirmNewPassword" class="form-control" minlength="6" required />
                        <small id="passError" class="text-danger fw-bold mt-1" style="display:none;">Passwords do not match.</small>
                    </div>
                </div>

                <button type="submit" id="submitBtn" class="btn btn-primary w-100 fw-bold shadow-sm">Verify & Set Password</button>
                
                <div class="text-center mt-3">
                    <a href="/Account/Login" class="text-decoration-none text-muted fw-bold small"><i class="bi bi-arrow-left"></i> Back to Login</a>
                </div>
            </form>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const newPass = document.getElementById('newPass');
            const confirmPass = document.getElementById('confirmPass');
            const passError = document.getElementById('passError');
            const submitBtn = document.getElementById('submitBtn');

            const checkPasswords = () => {
                const mismatch = confirmPass.value && newPass.value !== confirmPass.value;
                passError.style.display = mismatch ? 'block' : 'none';
                confirmPass.classList.toggle('is-invalid', mismatch);
                submitBtn.disabled = mismatch;
            };

            newPass.addEventListener('input', checkPasswords);
            confirmPass.addEventListener('input', checkPasswords);
        });
    </script>
}