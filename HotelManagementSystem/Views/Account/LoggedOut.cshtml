@{
    ViewData["Title"] = "Logged Out Successfully";
    ViewData["HideSidebar"] = true;
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 rounded-4 p-5 text-center bg-white" style="max-width: 500px;">
        
        <div class="mb-4">
            <div class="d-inline-flex justify-content-center align-items-center bg-light rounded-circle" style="width: 100px; height: 100px;">
                <i class="bi bi-door-closed text-primary" style="font-size: 3.5rem;"></i>
            </div>
        </div>
        
        <h2 class="fw-bold text-dark mb-3">You've safely logged out</h2>
        
        <p class="text-muted mb-5 px-2">
            Thank you for using the Hotel Management System. Your session has been securely closed. Have a wonderful day!
        </p>
        
        <div class="d-grid gap-1">
            <a href="/" class="btn btn-primary btn-lg fw-bold rounded-pill shadow-sm">
                <i class="bi bi-house-door me-2"></i> Return to Homepage
            </a>
        </div>
        
    </div>
</div>