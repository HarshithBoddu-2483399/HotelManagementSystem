@model HotelManagementSystem.ViewModels.GuestForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-primary">Reset Password</h2>
                        <p class="text-muted">Enter your details and 4-Digit PIN to securely reset your password.</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center fw-bold">@ViewBag.Error</div>
                    }

                    <form action="/Account/ForgotPassword" method="post">
                        <div class="mb-3">
                            <label class="fw-bold">Registered Email</label>
                            <input type="email" name="Email" class="form-control form-control-lg" required />
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">Registered Phone</label>
                            <input type="text" name="Phone" class="form-control form-control-lg" maxlength="10" required />
                        </div>
                        <div class="mb-4 p-3 bg-light border rounded">
                            <label class="fw-bold text-success">4-Digit Recovery PIN</label>
                            <input type="text" name="RecoveryPin" class="form-control form-control-lg border-success" maxlength="4" required />
                        </div>
                        <div class="mb-3">
                            <label class="fw-bold">New Password</label>
                            <input type="password" name="NewPassword" class="form-control form-control-lg" required />
                        </div>
                        <div class="mb-4">
                            <label class="fw-bold">Confirm Password</label>
                            <input type="password" name="ConfirmPassword" class="form-control form-control-lg" required />
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">Reset Password</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>