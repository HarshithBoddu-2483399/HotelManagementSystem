@model HotelManagementSystem.ViewModels.GuestForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    ViewData["HideSidebar"] = true;
}

<div class="col-md-6 col-lg-5 my-4">
    <div class="card glass-card">
        <div class="card-body p-4">
            <div class="text-center mb-3">
                <h3 class="fw-bold text-primary">Reset Password</h3>
                <p class="text-muted small">Enter your details and 4-Digit PIN to securely reset your password.</p>
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger text-center fw-bold py-2">
                    <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                </div>
            }

            <form asp-controller="Account" asp-action="ForgotPassword" method="post">
                <div class="mb-2">
                    <label class="fw-bold small mb-1">Registered Email</label>
                    <input type="email" name="Email" class="form-control" required />
                </div>
                
                <div class="mb-2">
                    <label class="fw-bold small mb-1">Registered Phone</label>
                    <input type="text" name="Phone" class="form-control" maxlength="10" required />
                </div>
                
                <div class="mb-3 p-2 bg-light border rounded">
                    <label class="fw-bold text-success small mb-1">4-Digit Recovery PIN</label>
                    <input type="text" name="RecoveryPin" class="form-control border-success" maxlength="4" required />
                </div>
                
                <div class="row mb-3">
                    <div class="col-sm-6 mb-2 mb-sm-0">
                        <label class="fw-bold small mb-1">New Password</label>
                        <input type="password" name="NewPassword" class="form-control" required />
                    </div>
                    <div class="col-sm-6">
                        <label class="fw-bold small mb-1">Confirm Password</label>
                        <input type="password" name="ConfirmPassword" class="form-control" required />
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 fw-bold shadow-sm">Reset Password</button>
                
                <div class="text-center mt-3">
                    <a href="/Account/Login" class="text-decoration-none text-muted fw-bold small"><i class="bi bi-arrow-left"></i> Back to Login</a>
                </div>
            </form>
            
        </div>
    </div>
</div>