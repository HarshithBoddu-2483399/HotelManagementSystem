@{
    ViewData["Title"] = "Update Password Required";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-lg border-0 rounded-4 border-top border-warning border-5">
                <div class="card-body p-5">
                    
                    <div class="text-center mb-4">
                        <i class="bi bi-shield-lock text-warning" style="font-size: 3rem;"></i>
                        <h3 class="fw-bold mt-2">Action Required</h3>
                        <p class="text-muted">Your password was reset by the hotel staff. For your security, you must create a new private password before accessing your dashboard.</p>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger text-center fw-bold">@ViewBag.Error</div>
                    }

                    <form action="/Account/ForceChangePassword" method="post">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">New Private Password</label>
                            <input type="password" name="newPassword" class="form-control form-control-lg" minlength="6" required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Confirm Password</label>
                            <input type="password" name="confirmPassword" class="form-control form-control-lg" minlength="6" required />
                        </div>

                        <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold shadow-sm">
                            Save & Continue to Login
                        </button>
                        
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>