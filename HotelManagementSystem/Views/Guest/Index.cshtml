@model IEnumerable<HotelManagementSystem.Models.Guest>

@{
    ViewData["Title"] = "Guests";
}

<div class="container">
    <h2>Guests</h2>
    <div class="table-responsive mt-3">
        <table class="table table-striped">
            <thead class="table-dark">
                <tr>
                    <th>Guest ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Contact</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var g in Model)
                {
                    <tr>
                        <td>@g.GuestId</td>
                        <td>@g.Name</td>
                        <td>@g.Email</td>
                        <td>@g.ContactInfo</td>
                        <td>
                            <form action="/Guest/ForceResetGuestPassword" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to force reset the password for @g.Name to Hotel@1234?');">
                                <input type="hidden" name="guestId" value="@g.GuestId" />
                                <button type="submit" class="btn btn-sm btn-outline-warning fw-bold">
                                    <i class="bi bi-key"></i> Force Reset Pass
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>