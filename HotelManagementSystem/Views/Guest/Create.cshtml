@model HotelManagementSystem.Models.Guest

@{
    ViewData["Title"] = "Register Guest";
}

<div class="container">
    <h2>Register New Guest</h2>
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form method="post" action="/Guest/Create" class="row g-3 mt-2">
        <div class="col-md-4">
            <label class="form-label">Name</label>
            <input class="form-control" name="Name" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Email</label>
            <input class="form-control" name="Email" type="email" required />
        </div>
        <div class="col-md-4">
            <label class="form-label">Contact</label>
            <input class="form-control" name="ContactInfo" />
        </div>
        <div class="col-12 mt-2">
            <button class="btn btn-primary" type="submit">Register Guest</button>
        </div>
    </form>
</div>