@{
    ViewData["Title"] = "Book a Room";
}

<div class="container">
    <h2>Book a Room</h2>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }

    <form action="/Reservation/Create" method="post" class="row g-3">
        
        <div class="col-md-4 position-relative">
            <label class="form-label">Phone</label>
            <input id="guestPhone" class="form-control" type="tel" name="guest.ContactInfo" placeholder="10-digit Mobile Number" autocomplete="off" required pattern="\d{10}" maxlength="10" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
            <div id="phoneSuggestions" class="list-group position-absolute shadow" style="z-index:1050; width:100%; display:none; max-height:200px; overflow:auto; top: 100%;"></div>
            <div id="registerPrompt" class="form-text text-danger mt-1" style="display:none; font-weight: 500;">
                Guest not found. <a id="registerLink" href="#" class="text-decoration-underline" style="cursor: pointer;">Register new guest</a>
            </div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Guest Name</label>
            <input id="guestName" class="form-control" type="text" name="guest.Name" placeholder="Guest Name" required />
        </div>

        <div class="col-md-4">
            <label class="form-label">Email</label>
            <input id="guestEmail" class="form-control" type="email" name="guest.Email" placeholder="Email Address" required pattern="[a-z0-9._%+-]+&#64;[a-z0-9.-]+\.[a-z]{2,}$" />
        </div>

        <div class="col-md-12">
            <label class="form-label">Room</label>
            <select id="roomSelect" class="form-select" name="reservation.RoomId" required>
                <option value="">-- Choose a Room --</option>
                @if (ViewBag.Rooms != null)
                {
                    foreach (var room in ViewBag.Rooms)
                    {
                        if (ViewBag.SelectedRoomId != null && ViewBag.SelectedRoomId == room.RoomId)
                        {
                            <option value="@room.RoomId" data-rate="@room.RatePerNight" selected>Room @room.RoomNumber (@room.RoomType) - ₹@room.RatePerNight</option>
                        }
                        else
                        {
                            <option value="@room.RoomId" data-rate="@room.RatePerNight">Room @room.RoomNumber (@room.RoomType) - ₹@room.RatePerNight</option>
                        }
                    }
                }
            </select>
            <div id="timeWarning" class="alert alert-danger mt-2 py-2 mb-0 fw-bold" style="display:none; font-size: 0.9rem;"></div>
        </div>

        <div class="col-md-4">
            <label class="form-label">Check-In</label>
            <div class="input-group">
                <input id="inDate" class="form-control" type="date" required />
                <select id="inTime" class="form-select" required style="max-width: 130px;">
                    <option value="" disabled selected>Time</option>
                    <option value="00:00">12:00 AM</option>
                    <option value="01:00">01:00 AM</option>
                    <option value="02:00">02:00 AM</option>
                    <option value="03:00">03:00 AM</option>
                    <option value="04:00">04:00 AM</option>
                    <option value="05:00">05:00 AM</option>
                    <option value="06:00">06:00 AM</option>
                    <option value="07:00">07:00 AM</option>
                    <option value="08:00">08:00 AM</option>
                    <option value="09:00">09:00 AM</option>
                    <option value="10:00">10:00 AM</option>
                    <option value="11:00">11:00 AM</option>
                    <option value="12:00">12:00 PM</option>
                    <option value="13:00">01:00 PM</option>
                    <option value="14:00">02:00 PM</option>
                    <option value="15:00">03:00 PM</option>
                    <option value="16:00">04:00 PM</option>
                    <option value="17:00">05:00 PM</option>
                    <option value="18:00">06:00 PM</option>
                    <option value="19:00">07:00 PM</option>
                    <option value="20:00">08:00 PM</option>
                    <option value="21:00">09:00 PM</option>
                    <option value="22:00">10:00 PM</option>
                    <option value="23:00">11:00 PM</option>
                </select>
            </div>
            <input type="hidden" name="reservation.CheckInDate" id="hiddenCheckIn" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Check-Out</label>
            <div class="input-group">
                <input id="outDate" class="form-control" type="date" required />
                <select id="outTime" class="form-select" required style="max-width: 130px;">
                    <option value="" disabled selected>Time</option>
                    <option value="00:00">12:00 AM</option>
                    <option value="01:00">01:00 AM</option>
                    <option value="02:00">02:00 AM</option>
                    <option value="03:00">03:00 AM</option>
                    <option value="04:00">04:00 AM</option>
                    <option value="05:00">05:00 AM</option>
                    <option value="06:00">06:00 AM</option>
                    <option value="07:00">07:00 AM</option>
                    <option value="08:00">08:00 AM</option>
                    <option value="09:00">09:00 AM</option>
                    <option value="10:00">10:00 AM</option>
                    <option value="11:00">11:00 AM</option>
                    <option value="12:00">12:00 PM</option>
                    <option value="13:00">01:00 PM</option>
                    <option value="14:00">02:00 PM</option>
                    <option value="15:00">03:00 PM</option>
                    <option value="16:00">04:00 PM</option>
                    <option value="17:00">05:00 PM</option>
                    <option value="18:00">06:00 PM</option>
                    <option value="19:00">07:00 PM</option>
                    <option value="20:00">08:00 PM</option>
                    <option value="21:00">09:00 PM</option>
                    <option value="22:00">10:00 PM</option>
                    <option value="23:00">11:00 PM</option>
                </select>
            </div>
            <input type="hidden" name="reservation.CheckOutDate" id="hiddenCheckOut" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Total Amount</label>
            <input id="totalPrice" class="form-control" type="text" readonly placeholder="₹0.00" />
            <small id="dateError" class="text-danger mt-1" style="display:none; font-weight:500;">Check-Out must be after Check-In.</small>
        </div>

        <div class="col-12 mt-4">
            <button id="bookBtn" class="btn btn-primary px-4" type="submit" disabled>Book Now</button>
        </div>
    </form>
</div>

<div class="modal fade" id="quickRegisterModal" tabindex="-1" aria-labelledby="quickRegisterModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="quickRegisterModalLabel">Register New Guest</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div id="modalError" class="alert alert-danger fw-bold shadow-sm" style="display:none; font-size: 0.9rem;"></div>
                
                <div class="mb-3">
                    <label class="form-label fw-bold">Phone Number</label>
                    <input type="text" id="modalPhone" class="form-control bg-light" readonly />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Full Name</label>
                    <input type="text" id="modalName" class="form-control" placeholder="John Doe" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Email Address</label>
                    <input type="email" id="modalEmail" class="form-control" placeholder="guest@example.com" required />
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success px-4" id="saveGuestBtn">Save & Auto-Fill</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const phoneInput = document.getElementById('guestPhone');
        const nameInput = document.getElementById('guestName');
        const emailInput = document.getElementById('guestEmail');
        const suggestionsEl = document.getElementById('phoneSuggestions');
        const registerPrompt = document.getElementById('registerPrompt');
        const registerLink = document.getElementById('registerLink');
        
        const inDate = document.getElementById('inDate');
        const inTime = document.getElementById('inTime');
        const outDate = document.getElementById('outDate');
        const outTime = document.getElementById('outTime');
        const hiddenCheckIn = document.getElementById('hiddenCheckIn');
        const hiddenCheckOut = document.getElementById('hiddenCheckOut');
        
        const roomSelect = document.getElementById('roomSelect');
        const totalEl = document.getElementById('totalPrice');
        const bookBtn = document.getElementById('bookBtn');
        const dateError = document.getElementById('dateError');
        const timeWarning = document.getElementById('timeWarning');

        let timeout = null;
        let quickModal = null; // Will hold our modal instance

        // Initialize bootstrap modal
        if (typeof bootstrap !== 'undefined') {
            quickModal = new bootstrap.Modal(document.getElementById('quickRegisterModal'));
        }

        const today = new Date();
        const yyyy = today.getFullYear();
        const mm = String(today.getMonth() + 1).padStart(2, '0');
        const dd = String(today.getDate()).padStart(2, '0');
        inDate.min = `${yyyy}-${mm}-${dd}`;

        inDate.addEventListener('change', function() {
            outDate.min = this.value;
            if (outDate.value && outDate.value < this.value) {
                outDate.value = this.value;
            }
        });

        [inDate, inTime, outDate, outTime, roomSelect].forEach(el => {
            if(el) el.addEventListener('change', validateAvailabilityAndTotal);
        });

        function validateAvailabilityAndTotal() {
            if (!inDate.value || !inTime.value || !outDate.value || !outTime.value || !roomSelect.value) {
                bookBtn.disabled = true;
                return;
            }

            const checkInStr = `${inDate.value}T${inTime.value}:00`;
            const checkOutStr = `${outDate.value}T${outTime.value}:00`;
            
            hiddenCheckIn.value = checkInStr;
            hiddenCheckOut.value = checkOutStr;

            const checkIn = new Date(checkInStr);
            const checkOut = new Date(checkOutStr);
            const diffTime = checkOut - checkIn;

            if (diffTime <= 0) {
                totalEl.value = "Invalid Dates";
                dateError.style.display = 'block';
                bookBtn.disabled = true;
                return;
            }

            dateError.style.display = 'none';

            const diffHours = diffTime / (1000 * 60 * 60);
            let daysToCharge = 0;

            if (diffHours <= 24) {
                daysToCharge = 1;
            } else {
                const fullDays = Math.floor(diffHours / 24);
                const extraHours = diffHours % 24;

                daysToCharge = fullDays;
                
                if (extraHours > 0 && extraHours <= 6) {
                    daysToCharge += 0.5;
                }
                else if (extraHours > 6) {
                    daysToCharge += 1;
                }
            }

            const url = `/Reservation/CheckAvailability?roomId=${roomSelect.value}&checkIn=${checkInStr}&checkOut=${checkOutStr}`;
            
            fetch(url)
                .then(res => res.json())
                .then(data => {
                    if(!data.available) {
                        timeWarning.innerText = data.message;
                        timeWarning.style.display = 'block';
                        bookBtn.disabled = true;
                        totalEl.value = "Room Blocked";
                    } else {
                        timeWarning.style.display = 'none';
                        bookBtn.disabled = false;
                        
                        const selected = roomSelect.options[roomSelect.selectedIndex];
                        const rate = parseFloat(selected.getAttribute('data-rate')) || 0;
                        const total = daysToCharge * rate;
                        
                        totalEl.value = total.toLocaleString('en-IN', { style: 'currency', currency: 'INR' });
                    }
                })
                .catch(err => console.error("Availability check failed", err));
        }

        function lookup(phone) {
            if (phone.length < 3) { hideSuggestions(); return; }
            
            fetch('/Guest/FindByPhone?phone=' + encodeURIComponent(phone))
                .then(res => res.json())
                .then(data => {
                    if (data && data.length > 0) {
                        const exactMatch = data.find(g => g.phone === phone);
                        if (exactMatch) {
                            nameInput.value = exactMatch.name;
                            emailInput.value = exactMatch.email;
                            registerPrompt.style.display = 'none';
                            hideSuggestions();
                        } else {
                            renderSuggestions(data);
                        }
                    } else {
                        hideSuggestions();
                        if (phone.length === 10) {
                            nameInput.value = '';
                            emailInput.value = '';
                            
                            // ---- NEW: Trigger Modal instead of changing URL ----
                            registerLink.onclick = function(e) {
                                e.preventDefault(); // Stop normal link click
                                document.getElementById('modalPhone').value = phone;
                                document.getElementById('modalName').value = '';
                                document.getElementById('modalEmail').value = '';
                                document.getElementById('modalError').style.display = 'none';
                                
                                if(quickModal) quickModal.show();
                            };
                            registerPrompt.style.display = 'block';
                        }
                    }
                });
        }

        phoneInput.addEventListener('input', function () {
            clearTimeout(timeout);
            const val = this.value.trim();
            registerPrompt.style.display = 'none';
            if (!val) { hideSuggestions(); return; }
            timeout = setTimeout(() => lookup(val), 300);
        });

        function renderSuggestions(list) {
            suggestionsEl.innerHTML = '';
            list.forEach(item => {
                const btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'list-group-item list-group-item-action';
                btn.innerHTML = `<strong>${item.phone}</strong> - ${item.name}`;
                btn.onclick = () => {
                    phoneInput.value = item.phone;
                    nameInput.value = item.name;
                    emailInput.value = item.email;
                    hideSuggestions();
                };
                suggestionsEl.appendChild(btn);
            });
            suggestionsEl.style.display = 'block';
        }

        function hideSuggestions() { suggestionsEl.style.display = 'none'; }
        
        document.addEventListener('click', (e) => {
            if (!phoneInput.contains(e.target)) hideSuggestions();
        });

        // ==========================================
        // NEW: AJAX Save Logic for the Modal
        // ==========================================
        document.getElementById('saveGuestBtn').addEventListener('click', function() {
            const btn = this;
            const phone = document.getElementById('modalPhone').value;
            const name = document.getElementById('modalName').value.trim();
            const email = document.getElementById('modalEmail').value.trim();
            const errorDiv = document.getElementById('modalError');

            if(!name || !email) {
                errorDiv.innerText = "Please fill in all fields.";
                errorDiv.style.display = 'block';
                return;
            }

            // Disable button to prevent double-clicks
            btn.disabled = true;
            btn.innerText = "Saving...";

            const guestData = {
                ContactInfo: phone,
                Name: name,
                Email: email
            };

            fetch('/Guest/CreateAjax', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(guestData)
            })
            .then(res => res.json())
            .then(data => {
                if(data.success) {
                    // Success! Auto-fill the main booking form
                    phoneInput.value = data.guest.phone;
                    nameInput.value = data.guest.name;
                    emailInput.value = data.guest.email;
                    
                    registerPrompt.style.display = 'none';
                    if(quickModal) quickModal.hide();
                } else {
                    // Show error in the modal (e.g. duplicate email)
                    errorDiv.innerText = data.message;
                    errorDiv.style.display = 'block';
                }
            })
            .catch(err => {
                errorDiv.innerText = "A network error occurred. Please try again.";
                errorDiv.style.display = 'block';
            })
            .finally(() => {
                // Reset button
                btn.disabled = false;
                btn.innerText = "Save & Auto-Fill";
            });
        });
    });
</script>