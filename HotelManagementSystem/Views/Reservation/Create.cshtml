<h2>Book a Room</h2>
@if (ViewBag.Error != null)
{
    <p style="color:red;">@ViewBag.Error</p>
}
<form action="/Reservation/Create" method="post">
    <input type="text" name="guest.Name" placeholder="Guest Name" required />
    <input type="email" name="guest.Email" placeholder="Email" required />
    <input type="text" name="guest.ContactInfo" placeholder="Phone" required /><br /><br />
    
    <select name="reservation.RoomId">
        @foreach (var room in ViewBag.Rooms)
        {
            <option value="@room.RoomId">Room @room.RoomNumber ($@room.RatePerNight)</option>
        }
    </select><br /><br />
    
    Check-In: <input type="date" name="reservation.CheckInDate" required />
    Check-Out: <input type="date" name="reservation.CheckOutDate" required /><br /><br />
    <button type="submit">Book Now</button>
</form>