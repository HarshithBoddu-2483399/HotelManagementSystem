@model IEnumerable<HotelManagementSystem.Models.HousekeepingTask>

@{
    ViewData["Title"] = "Housekeeping";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Housekeeping - Pending Tasks</h2>
        <a href="/Housekeeping/AllTasks" class="btn btn-info">View All Tasks</a>
    </div>

    <div class="card mt-3 p-3">
        <div class="table-responsive mt-3">
            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Task ID</th>
                        <th>Room ID</th>
                        <th>Assigned Staff ID</th>
                        <th>Task Date</th>
                        <th>Task Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td>@t.TaskId</td>
                            <td>@t.RoomId</td>
                            <td>@t.AssignedStaffId</td>
                            <td>@t.TaskDate.ToShortDateString()</td>
                            <td><span class="badge bg-warning text-dark">@t.TaskStatus</span></td>
                            <td>
                                <form action="/Housekeeping/MarkClean" method="post" style="display:inline-block;">
                                    <input type="hidden" name="taskId" value="@t.TaskId" />
                                    <button type="submit" class="btn btn-sm btn-success">Mark Clean</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-success mt-3">No pending tasks. All rooms are clean!</div>
        }
    </div>
</div>
