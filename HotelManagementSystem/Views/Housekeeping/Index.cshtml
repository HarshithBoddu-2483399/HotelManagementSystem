@model IEnumerable<HotelManagementSystem.Models.HousekeepingTask>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Active Housekeeping Tasks</h2>
        <span class="badge bg-dark px-3 py-2">Pending & Assigned</span>
    </div>

    <div class="card shadow-sm border-0">
        <table class="table align-middle mb-0 table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Room Number</th>
                    <th>Assigned Staff</th>
                    <th>Task Status</th>
                    <th>Scheduled Deadline</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-4 text-muted">
                            <i class="bi bi-check-circle fs-4 d-block mb-2 text-success"></i>
                            All caught up! No pending or assigned tasks right now.
                        </td>
                    </tr>
                }
                
                @foreach (var task in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">Room @task.RoomId</td>
                        
                        <td>
                            @if (task.AssignedStaffId == 0)
                            {
                                <span class="text-muted fst-italic">Not Assigned</span>
                            }
                            else
                            {
                                <span class="fw-bold">Staff ID: @task.AssignedStaffId</span>
                            }
                        </td>
                        
                        <td>
                            @if (task.TaskStatus == "PENDING")
                            {
                                <span class="badge bg-danger px-2 py-1">@task.TaskStatus</span>
                            }
                            else if (task.TaskStatus == "ASSIGNED")
                            {
                                <span class="badge bg-warning text-dark px-2 py-1">@task.TaskStatus</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary px-2 py-1">@task.TaskStatus</span>
                            }
                        </td>
                        
                        <td>@task.TaskDate.ToString("MMM dd, yyyy - hh:mm tt")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>