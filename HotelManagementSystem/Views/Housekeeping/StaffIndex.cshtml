@model IEnumerable<HotelManagementSystem.Models.HousekeepingTask>

@{
    ViewData["Title"] = "My Cleaning Tasks";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">My Daily Tasks</h2>
            <p class="text-muted">Welcome, @User.Identity.Name</p>
        </div>
        <span class="badge bg-dark px-3 py-2">Staff Portal</span>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-success text-center p-5 shadow-sm">
            <h4 class="mb-0">🎉 All caught up! No pending tasks assigned to you.</h4>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var task in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card shadow-sm border-0" style="border-left: 5px solid #ffc107;">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h3 class="mb-0 fw-bold text-primary">Room @task.RoomId</h3>
                                <span class="badge bg-warning text-dark text-uppercase">@task.TaskStatus</span>
                            </div>
                            
                            <p class="mb-4 text-muted">
                                <i class="bi bi-calendar-event"></i> Assigned: @task.TaskDate.ToString("MMM dd, hh:mm tt")
                            </p>

                            <form asp-action="CompleteTask" method="post">
                                <input type="hidden" name="taskId" value="@task.TaskId" />
                                <button type="submit" class="btn btn-success btn-lg w-100 fw-bold py-3">
                                    <i class="bi bi-check-circle-fill"></i> Mark as Cleaned
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<div style="height: 100px;"></div>