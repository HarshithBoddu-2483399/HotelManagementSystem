@model HotelManagementSystem.ViewModels.OccupancyReportViewModel

@{
    ViewData["Title"] = "Occupancy Report";
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Occupancy Report</h2>
        @if (User.IsInRole("Manager"))
        {
            <a href="/Manager/Index" class="btn btn-outline-secondary">Back to Dashboard</a>
        }
        else
        {
            <a href="/Report/Index" class="btn btn-outline-secondary">Back to Dashboard</a>
        }
    </div>

    <!-- Date Selector -->
    <div class="card mb-4 p-3">
        <h5>Select Date</h5>
        <form method="get" action="/Report/OccupancyReport" class="row g-3">
            <div class="col-md-4">
                <label for="reportDate" class="form-label">Report Date</label>
                <input type="date" class="form-control" id="reportDate" name="reportDate" 
                       value="@Model.ReportDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-8 d-flex align-items-end gap-2">
                <button type="submit" class="btn btn-primary">Generate Report</button>
                <a href="/Report/OccupancyReport" class="btn btn-outline-secondary">Reset to Today</a>
            </div>
        </form>
    </div>

    <!-- Report Details -->
    <div class="card mt-4">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Occupancy Report for @Model.ReportDate.ToString("MMMM dd, yyyy")</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Metric</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Report Date</strong></td>
                            <td>@Model.ReportDate.ToString("MMMM dd, yyyy")</td>
                        </tr>
                        <tr>
                            <td><strong>Total Rooms</strong></td>
                            <td>@Model.TotalRooms</td>
                        </tr>
                        <tr>
                            <td><strong>Occupied Rooms</strong></td>
                            <td>@Model.OccupiedRooms</td>
                        </tr>
                        <tr>
                            <td><strong>Occupancy Rate</strong></td>
                            <td>
                                <span class="badge bg-info" style="font-size: 1rem;">@Model.OccupancyRate%</span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Revenue Generated</strong></td>
                            <td>
                                <span class="badge bg-success" style="font-size: 1rem;">@Model.RevenueGenerated.ToString("C")</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Summary Cards -->
            <div class="row mt-4">
                <div class="col-md-3">
                    <div class="card text-center border-info">
                        <div class="card-body">
                            <h6 class="card-title text-muted">Total Rooms</h6>
                            <h3 class="text-info">@Model.TotalRooms</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-success">
                        <div class="card-body">
                            <h6 class="card-title text-muted">Occupied</h6>
                            <h3 class="text-success">@Model.OccupiedRooms</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-warning">
                        <div class="card-body">
                            <h6 class="card-title text-muted">Occupancy Rate</h6>
                            <h3 class="text-warning">@Model.OccupancyRate%</h3>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-success">
                        <div class="card-body">
                            <h6 class="card-title text-muted">Revenue</h6>
                            <h3 class="text-success">@Model.RevenueGenerated.ToString("C")</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .border-info { border-left: 4px solid #17a2b8 !important; }
    .border-success { border-left: 4px solid #28a745 !important; }
    .border-warning { border-left: 4px solid #ffc107 !important; }
</style>
