@model HotelManagementSystem.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container">
    <h2>Manager Dashboard</h2>

    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6 class="text-uppercase text-muted">Total Revenue</h6>
                <h3 class="mt-2">@Model.TotalRevenue.ToString("C")</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6 class="text-uppercase text-muted">Pending Tasks</h6>
                <h3 class="mt-2">@Model.PendingTasks</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm p-3">
                <h6 class="text-uppercase text-muted">Rooms Available</h6>
                <h3 class="mt-2">@Model.RoomsAvailable</h3>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Occupancy Breakdown</h5>
                <div style="max-width:320px; margin:0 auto;">
                    <canvas id="occupancyPieChart" width="320" height="240"></canvas>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3">
                <h5>Rooms Summary</h5>
                <ul class="list-unstyled mb-0">
                    <li><strong>Available:</strong> @Model.RoomsAvailable</li>
                    <li><strong>Occupied:</strong> @Model.RoomsOccupied</li>
                    <li><strong>Maintenance:</strong> @Model.RoomsMaintenance</li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        var ctx = document.getElementById('occupancyPieChart').getContext('2d');
        new Chart(ctx, {
            type: 'pie',
            data: {
                labels: ['Available', 'Occupied', 'Maintenance' , 'Dirty'],
                datasets: [{
                    data: [@Model.RoomsAvailable, @Model.RoomsOccupied, @Model.RoomsMaintenance, @Model.PendingTasks],
                    backgroundColor: ['#28a745', '#007bff', '#ffc107' , '#dc3545']
                }]
            },
            options: { responsive: true }
        });
    });
</script>
