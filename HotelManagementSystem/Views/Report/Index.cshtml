@model HotelManagementSystem.ViewModels.DashboardViewModel

<h2>Manager Dashboard & Occupancy Report</h2>
<hr />

<div style="display:flex; gap:20px; margin-bottom: 40px;">
    <div style="padding:20px; border:1px solid #ddd; border-radius: 8px; width: 250px; text-align: center; box-shadow: 2px 2px 10px rgba(0,0,0,0.1);">
        <h3 style="color:green; margin-top:0;">Monthly Revenue</h3>
        <h2>$@Model.TotalRevenue</h2>
    </div>
    <div style="padding:20px; border:1px solid #ddd; border-radius: 8px; width: 250px; text-align: center; box-shadow: 2px 2px 10px rgba(0,0,0,0.1);">
        <h3 style="color:red; margin-top:0;">Pending Cleaning</h3>
        <h2>@Model.PendingTasks</h2>
    </div>
</div>

<div style="width: 400px; height: 400px; margin: 0 auto; padding: 20px; border:1px solid #ddd; border-radius: 8px; box-shadow: 2px 2px 10px rgba(0,0,0,0.1); background-color: white;">
    <h3 style="text-align: center;">Live Occupancy Breakdown</h3>
    <canvas id="occupancyPieChart"></canvas>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const ctx = document.getElementById('occupancyPieChart').getContext('2d');
        
        new Chart(ctx, {
            type: 'pie', 
            data: {
                labels: ['Available', 'Occupied', 'Maintenance'],
                datasets: [{
                    // Notice how we use @Model right inside the JavaScript!
                    data: [@Model.RoomsAvailable, @Model.RoomsOccupied, @Model.RoomsMaintenance],
                    backgroundColor: [
                        '#28a745', // Green for Available
                        '#007bff', // Blue for Occupied
                        '#ffc107'  // Yellow for Maintenance
                    ],
                    borderColor: '#ffffff',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                    }
                }
            }
        });
    });
</script>