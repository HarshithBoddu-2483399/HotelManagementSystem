@model HotelManagementSystem.ViewModels.RevenueAnalysisViewModel

@{
    ViewData["Title"] = "Revenue Analysis";
    var selectedRange = ViewBag.SelectedDateRange ?? "thismonth";
}

<div class="mb-3">
    @if (User.IsInRole("Manager"))
    {
        <a asp-controller="Manager" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Manager Dashboard
        </a>
    }
    else if (User.IsInRole("Admin"))
    {
        <a asp-controller="Report" asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Admin Dashboard
        </a>
    }
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Revenue Analysis</h2>
        <a href="/Report/Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>

    <div class="card mb-4 p-3">
        <h5 class="mb-3">Quick Date Ranges</h5>
        <div class="btn-group" role="group">
            <a href="/Report/RevenueAnalysis?dateRange=last7days" 
               class="btn @(selectedRange == "last7days" ? "btn-primary" : "btn-outline-primary")">
                Last 7 Days
            </a>
            <a href="/Report/RevenueAnalysis?dateRange=lastmonth" 
               class="btn @(selectedRange == "lastmonth" ? "btn-primary" : "btn-outline-primary")">
                Last Month
            </a>
            <a href="/Report/RevenueAnalysis?dateRange=thismonth" 
               class="btn @(selectedRange == "thismonth" ? "btn-primary" : "btn-outline-primary")">
                This Month
            </a>
            <a href="/Report/RevenueAnalysis?dateRange=yeartodate" 
               class="btn @(selectedRange == "yeartodate" ? "btn-primary" : "btn-outline-primary")">
                Year to Date
            </a>
        </div>
    </div>

    <!-- Custom Date Range -->
    <div class="card mb-4 p-3">
        <h5>Custom Date Range</h5>
        <form method="get" action="/Report/RevenueAnalysis" class="row g-3">
            <div class="col-md-4">
                <label for="startDate" class="form-label">Start Date</label>
                <input type="date" class="form-control" id="startDate" name="startDate" 
                       value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label for="endDate" class="form-label">End Date</label>
                <input type="date" class="form-control" id="endDate" name="endDate" 
                       value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4 d-flex align-items-end gap-2">
                <input type="hidden" name="dateRange" value="custom" />
                <button type="submit" class="btn btn-primary">Apply Custom Range</button>
            </div>
        </form>
    </div>

    <!-- Revenue Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center border-success h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted">Total Revenue</h6>
                    <h3 class="text-success">@Model.TotalRevenue.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-info h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted">Avg Daily Revenue</h6>
                    <h3 class="text-info">@Model.AverageRevenuePerDay.ToString("C")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-warning h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted">Invoice Count</h6>
                    <h3 class="text-warning">@Model.InvoiceCount</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center border-secondary h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted">Date Range</h6>
                    <p class="mb-0"><strong>@Model.DateRange</strong></p>
                    <small class="text-muted">@Model.StartDate.ToString("MMM dd") - @Model.EndDate.ToString("MMM dd, yyyy")</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Detailed Summary Table -->
    <div class="card">
        <div class="card-header bg-dark text-white">
            <h5 class="mb-0">Revenue Summary - @Model.DateRange</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Metric</th>
                            <th>Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Period</strong></td>
                            <td>@Model.StartDate.ToString("MMMM dd, yyyy") to @Model.EndDate.ToString("MMMM dd, yyyy")</td>
                        </tr>
                        <tr>
                            <td><strong>Total Revenue</strong></td>
                            <td>
                                <span class="badge bg-success" style="font-size: 1rem;">@Model.TotalRevenue.ToString("C")</span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Average Daily Revenue</strong></td>
                            <td>
                                <span class="badge bg-info" style="font-size: 1rem;">@Model.AverageRevenuePerDay.ToString("C")</span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Number of Invoices (Paid)</strong></td>
                            <td>
                                <span class="badge bg-warning text-dark" style="font-size: 1rem;">@Model.InvoiceCount</span>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Days in Period</strong></td>
                            <td>@((Model.EndDate - Model.StartDate).Days + 1) days</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .border-success { border-left: 4px solid #28a745 !important; }
    .border-info { border-left: 4px solid #17a2b8 !important; }
    .border-warning { border-left: 4px solid #ffc107 !important; }
    .border-secondary { border-left: 4px solid #6c757d !important; }
</style>
