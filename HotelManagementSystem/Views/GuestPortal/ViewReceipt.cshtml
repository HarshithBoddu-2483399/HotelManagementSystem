@model HotelManagementSystem.Models.Invoice

@{
    ViewData["Title"] = "Receipt #" + Model.InvoiceId;
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-5">
                    
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-4 mb-4">
                        <div>
                            <h2 class="fw-bold text-primary mb-0"><i class="bi bi-building"></i> Hotel Portal</h2>
                            <p class="text-muted mb-0">Official Guest Receipt</p>
                        </div>
                        <div class="text-end">
                            <h4 class="fw-bold mb-0">Invoice #@Model.InvoiceId</h4>
                            <p class="text-muted mb-0">Date: @Model.InvoiceDate.ToString("MMM dd, yyyy")</p>
                            <span class="badge bg-success mt-2 px-3 py-2 fs-6">PAID</span>
                        </div>
                    </div>

                    <div class="row mb-5">
                        <div class="col-sm-6">
                            <h6 class="text-muted fw-bold text-uppercase mb-3">Billed To:</h6>
                            <h5 class="fw-bold mb-1">@ViewBag.Guest.Name</h5>
                            <p class="text-muted mb-0">@ViewBag.Guest.Email<br>@ViewBag.Guest.ContactInfo</p>
                        </div>
                        <div class="col-sm-6 text-end">
                            <h6 class="text-muted fw-bold text-uppercase mb-3">Stay Details:</h6>
                            <p class="mb-1"><strong>Room:</strong> @ViewBag.Room.RoomNumber <span class="text-muted">(@ViewBag.Room.RoomType)</span></p>
                            <p class="mb-1"><strong>Check-In:</strong> @ViewBag.Reservation.CheckInDate.ToString("MMM dd, yyyy hh:mm tt")</p>
                            <p class="mb-0"><strong>Check-Out:</strong> @ViewBag.Reservation.CheckOutDate.ToString("MMM dd, yyyy hh:mm tt")</p>
                        </div>
                    </div>

                    <table class="table border mb-4">
                        <thead class="table-light">
                            <tr>
                                <th class="py-3">Description</th>
                                <th class="text-end py-3">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="py-3">Room Charges (@ViewBag.Room.RoomType)</td>
                                <td class="text-end py-3">@Model.TotalAmount.ToString("C")</td>
                            </tr>
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td class="text-end fw-bold py-3 fs-5">Total Paid:</td>
                                <td class="text-end fw-bold py-3 fs-5 text-success">@Model.TotalAmount.ToString("C")</td>
                            </tr>
                        </tfoot>
                    </table>

                    <div class="text-center mt-5 pt-3 border-top d-print-none">
                        <p class="text-muted mb-4">Thank you for choosing to stay with us!</p>
                        <button onclick="window.close()" class="btn btn-outline-secondary me-2">
                            <i class="bi bi-x-circle"></i> Close Window
                        </button>
                        <button onclick="window.print()" class="btn btn-primary px-4">
                            <i class="bi bi-printer"></i> Print Receipt
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        /* Set standard printer margins */
        @@page {
            margin: 0.5cm;
        }
        /* Remove the large screen margins and padding */
        body, .container {
            margin: 0 !important;
            padding: 0 !important;
            max-width: 100% !important;
            width: 100% !important;
        }
        /* Remove the huge padding inside the receipt card */
        .card-body {
            padding: 0 !important;
        }
        /* Hide buttons and web layout elements */
        .d-print-none, nav, header, footer {
            display: none !important;
        }
        /* Remove card borders for a clean paper look */
        .card {
            border: none !important;
            box-shadow: none !important;
        }
    }
</style>