@model HotelManagementSystem.ViewModels.GuestDashboardViewModel

@{
    ViewData["Title"] = "My Stay Dashboard";
}

<div class="container mt-4">
    <div class="row mb-4 align-items-center">
        <div class="col-md-8">
            <h2 class="fw-bold">Welcome back, @Model.Guest.Name!</h2>
            <p class="text-muted mb-0">Manage your upcoming stays and view past receipts.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a href="/GuestPortal/BookRoom" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-calendar-plus me-2"></i> Book a New Stay
            </a>
        </div>
    </div>

    <h4 class="fw-bold mb-3 mt-5 border-bottom pb-2">Your Active & Upcoming Stays</h4>
    
    @if (!Model.ActiveBookings.Any())
    {
        <div class="alert alert-light text-center py-5 border shadow-sm rounded-3">
            <i class="bi bi-luggage text-muted" style="font-size: 3rem;"></i>
            <h5 class="mt-3 text-muted">You have no upcoming stays.</h5>
            <a href="/GuestPortal/BookRoom" class="btn btn-outline-primary mt-2">Plan your next trip</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var b in Model.ActiveBookings)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm border-0 h-100" style="border-left: 5px solid #0d6efd !important;">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="badge bg-primary fs-6 px-3 py-2">@b.Status</span>
                                <small class="text-muted">Res #@b.ReservationId</small>
                            </div>
                            
                            <h4 class="card-title fw-bold">Room @b.RoomNumber</h4>
                            <p class="text-muted mb-4">@b.RoomType</p>
                            
                            <div class="row text-center mb-3 bg-light rounded-3 py-3 mx-0">
                                <div class="col-5 border-end">
                                    <small class="text-muted d-block fw-bold text-uppercase">Check-In</small>
                                    <strong class="fs-5">@b.CheckIn.ToString("MMM dd")</strong><br />
                                    <small class="text-muted">@b.CheckIn.ToString("hh:mm tt")</small>
                                </div>
                                <div class="col-2 d-flex align-items-center justify-content-center text-muted">
                                    <i class="bi bi-arrow-right"></i>
                                </div>
                                <div class="col-5">
                                    <small class="text-muted d-block fw-bold text-uppercase">Check-Out</small>
                                    <strong class="fs-5">@b.CheckOut.ToString("MMM dd")</strong><br />
                                    <small class="text-muted">@b.CheckOut.ToString("hh:mm tt")</small>
                                </div>
                            </div>
                            
                            @if (b.Status == "BOOKED" || b.Status == "PENDING")
                            {
                                <div class="text-end mt-3 border-top pt-3">
                                    <form action="/GuestPortal/CancelBooking" method="post" onsubmit="return confirm('Are you sure you want to cancel this booking? This action cannot be undone.');">
                                        <input type="hidden" name="reservationId" value="@b.ReservationId" />
                                        <button type="submit" class="btn btn-outline-danger btn-sm">
                                            <i class="bi bi-x-circle me-1"></i> Cancel Booking
                                        </button>
                                    </form>
                                </div>
                            }

                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <h4 class="fw-bold mb-3 mt-5 border-bottom pb-2">Past Stays & Receipts</h4>
    
    @if (!Model.PastBookings.Any())
    {
        <p class="text-muted">No past stays found.</p>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Dates</th>
                            <th>Room</th>
                            <th>Status</th>
                            <th>Total Amount</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in Model.PastBookings)
                        {
                            <tr>
                                <td>
                                    <strong>@b.CheckIn.ToString("MMM dd, yyyy")</strong><br />
                                    <small class="text-muted">to @b.CheckOut.ToString("MMM dd, yyyy")</small>
                                </td>
                                <td>Room @b.RoomNumber <br /><small class="text-muted">@b.RoomType</small></td>
                                <td>
                                    @if (b.Status == "CANCELLED")
                                    {
                                        <span class="badge bg-danger">Cancelled</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">@b.Status</span>
                                    }
                                </td>
                                <td>
                                    @if (b.TotalAmount > 0)
                                    {
                                        <strong>@b.TotalAmount.ToString("C")</strong>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    @if (b.InvoiceId != null && b.IsPaid)
                                    {
                                        <a href="/GuestPortal/ViewReceipt?reservationId=@b.ReservationId" class="btn btn-sm btn-outline-dark" target="_blank">
                                            <i class="bi bi-receipt"></i> View Receipt
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>