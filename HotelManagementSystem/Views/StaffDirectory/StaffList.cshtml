@model IEnumerable<HotelManagementSystem.Models.User>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Staff Directory</h2>
        <a asp-action="AddStaff" class="btn btn-primary">+ Add Employee</a>
    </div>

    <table class="table table-striped shadow-sm align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Department</th>
                <th>Phone</th>
                <th>Login Email</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var staff in Model)
            {
                <tr>
                    <td class="fw-bold">@staff.UserId</td>
                    <td>@staff.Name</td>
                    <td><span class="badge bg-secondary">@staff.Role</span></td>
                    <td>@staff.Phone</td>
                    <td>@staff.Username</td>
                    <td>
                        <div class="d-flex gap-2">
                            <a asp-action="EditStaff" asp-route-userId="@staff.UserId" class="btn btn-sm btn-primary">
                                Edit
                            </a>
        
                            <form asp-action="DeleteStaff" method="post" onsubmit="return confirm('Are you sure you want to delete @staff.Name?');">
                                <input type="hidden" name="userId" value="@staff.UserId" />
                                <button type="submit" class="btn btn-sm btn-danger">
                                    Delete
                                </button>
                            </form>

                            <button type="button" class="btn btn-sm btn-outline-danger fw-bold" data-bs-toggle="modal" data-bs-target="#resetPasswordModal-@staff.UserId">
                                <i class="bi bi-key-fill"></i> Reset Password
                            </button>
                            <div class="modal fade" id="resetPasswordModal-@staff.UserId" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content shadow-lg border-0">
                                        <div class="modal-header bg-danger text-white border-0">
                                            <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i> Force Password Reset</h5>
                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
            
                                        <form asp-controller="StaffDirectory" asp-action="ForcePasswordReset" method="post">
                                            <div class="modal-body p-4">
                                                <p class="text-muted mb-3">You are about to reset the password for <strong>@staff.Name</strong>. Please provide a new secure password.</p>
                    
                                                <input type="hidden" name="userId" value="@staff.UserId" />
                    
                                                <div class="mb-3">
                                                    <label class="form-label fw-bold">New Password</label>
                                                    <input type="text" name="newPassword" class="form-control" required minlength="6" placeholder="Enter new password..." autocomplete="off" />
                                                    <div class="form-text">We recommend a minimum of 6 characters.</div>
                                                </div>
                                            </div>
                                            <div class="modal-footer bg-light border-0">
                                                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-danger px-4 fw-bold">Reset Password</button>
                                            </div>
                                        </form>
            
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>