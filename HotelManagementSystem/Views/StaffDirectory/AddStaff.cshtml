@model HotelManagementSystem.Models.User

<div class="container mt-4">
    <div class="card shadow-sm border-0 p-4" style="max-width: 500px; margin: auto;">
        <h2 class="fw-bold mb-3">Add New Staff</h2>
        <p class="text-muted">Create login credentials for the new employee.</p>
        <hr />

        <form asp-action="AddStaff" method="post">
            <div class="mb-3">
                <label class="form-label fw-bold">Full Name</label>
                <input type="text" asp-for="Name" class="form-control" placeholder="Enter Full Name" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Phone Number</label>
                <input type="text" asp-for="Phone" class="form-control" required
                       maxlength="10" minlength="10"
                       pattern="[0-9]{10}"
                       oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Login Username</label>
                <input type="text" asp-for="Username" class="form-control" placeholder="e.g. rahul_reception" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Login Password</label>
                <input type="password" asp-for="Password" class="form-control" placeholder="Create Password" required />
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Department / Role</label>
                <select asp-for="Role" class="form-select" required>
                    <option value="Receptionist">Receptionist (Front Desk)</option>
                    <option value="Housekeeping">Housekeeping</option>
                    <option value="Manager">Manager</option>
                </select>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary w-100 fw-bold">Create Employee Account</button>
                <a asp-action="StaffList" class="btn btn-link w-100 mt-2 text-muted">Cancel and Go Back</a>
            </div>
        </form>
    </div>
</div>