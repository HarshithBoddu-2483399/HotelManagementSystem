@model HotelManagementSystem.Models.User

<div class="container mt-4">
    <h2>Edit Staff Details</h2>
    <hr />
    
    <div class="alert alert-secondary">
        <i class="bi bi-shield-lock"></i> <strong>Login Details Locked:</strong> For security reasons, the employee's login email and password cannot be modified.
    </div>

    <form asp-action="EditStaff" method="post" class="mt-4" style="max-width: 500px;">
        <input type="hidden" asp-for="UserId" />

        <div class="mb-3">
            <label class="fw-bold">Login Email (Read-Only)</label>
            <input type="text" class="form-control bg-light" value="@Model.Username" readonly />
        </div>

        <div class="mb-3">
            <label class="fw-bold">Full Name</label>
            <input type="text" asp-for="Name" class="form-control" required />
        </div>
        
        <div class="mb-3">
            <label class="fw-bold">Phone Number</label>
            <input type="text" asp-for="Phone" class="form-control" required
                   maxlength="10" minlength="10" pattern="[0-9]{10}"
                   oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
        </div>
        
        <div class="mb-3">
            <label class="fw-bold">Department / Role</label>
            <select asp-for="Role" class="form-select" required>
                <option value="Housekeeping">Housekeeping</option>
                <option value="Receptionist">Receptionist</option>
                <option value="Manager">Manager</option>
            </select>
        </div>
        
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a asp-action="StaffList" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
</div>